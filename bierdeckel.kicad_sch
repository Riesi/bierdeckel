	(text_box "Idea: \n0.Initially PSU_EN is low due to the 2M2 pull-down.\n1.When pressing SW1 the buck/boost gets enabled and it will sustain itself via 3v3.\n2.The uC monitors the PSU_EN_SENSE line, which will have a certain low voltage on 3v3.\n3.When pressing SW1 again the uC can detect the voltage change from the resistor dividers.\n4.On detection the PSU_EN line is pulled down with the MOSFET.\n5.This should shut down the whole circuit."
		(exclude_from_sim no)
		(at 88.9 91.44 0)
		(size 93.98 17.78)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "4db60fba-ad5d-4dcc-b6ec-b4af8965b0da")
	)
